900844766\n","bestIteration = 737\n","\n","Shrink model to first 738 iterations.\n","Fold 5 PR-AUC: 0.490148\n","\n","==============================\n","Fold scores: [np.float64(0.505225167274973), np.float64(0.49920242150643), np.float64(0.5043400565182179), np.float64(0.4984822122513162), np.float64(0.4901477481521835)]\n","Mean CV PR-AUC: 0.49947952114062416\n","OOF PR-AUC: 0.49918001449586213\n"]}]},{"cell_type":"code","source":["submission = sample_submission.copy()\n","\n","submission[\"label_noshow\"] = test_preds_cat\n","\n","submission.head()"],"metadata":{"id":"11AdkS9y4NoJ","executionInfo":{"status":"ok","timestamp":1773484005033,"user_tz":-180,"elapsed":53,"user":{"displayName":"","userId":""}},"outputId":"f1201a09-b58a-4372-8bb8-154614b7dcbf","colab":{"base_uri":"https://localhost:8080/","height":206}},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["   appointment_id  label_noshow\n","0          200001      0.142480\n","1          200002      0.122685\n","2          200003      0.196612\n","3          200004      0.231802\n","4          200005      0.263868"],"text/html":["\n","  <div id=\"df-e0070cd2-1dc8-4ad5-8bdd-0e0119876da9\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>appointment_id</th>\n","      <th>label_noshow</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>200001</td>\n","      <td>0.142480</td>\n","    </tr>\n","    <tr>\n","      <th>1</th>\n","      <td>200002</td>\n","      <td>0.122685</td>\n","    </tr>\n","    <tr>\n","      <th>2</th>\n","