non-null  int64  \n"," 21  prior_noshow_count     200000 non-null  int64  \n"," 22  prior_noshow_rate      200000 non-null  float64\n"," 23  area_id                200000 non-null  int64  \n"," 24  capacity_daily         200000 non-null  int64  \n"," 25  base_wait_mins_est     200000 non-null  float64\n"," 26  open_on_saturday       200000 non-null  int64  \n"," 27  sms_policy_prob        200000 non-null  float64\n"," 28  is_cold_start_clinic   200000 non-null  int64  \n","dtypes: float64(9), int64(16), object(4)\n","memory usage: 44.3+ MB\n"]}]},{"cell_type":"code","source":["# CatBoost için ham veriyi yeniden kuruyoruz\n","X_cat = train_df.drop(columns=[\"label_noshow\"]).copy()\n","y_cat = train_df[\"label_noshow\"].copy()\n","\n","X_test_cat = test_df.copy()\n","\n","# CatBoost'ta kategorik kolonları açıkça belirteceğiz\n","cat_cols = [\"specialty_x\", \"booking_channel\", \"appointment_type\", \"sex\"]\n","\n","print(\"X_cat shape:\", X_cat.shape)\n","print(\"X_test_cat shape:\", X_test_cat.shape)\n","print(\"Categorical columns:\", cat_cols)"],"metadata":{"id":"bEq5__TE2Ys7","executionInfo":{"status":"ok","timestamp":1773483640783,"user_tz":-180,"elapsed":32,"user":{"displayName":"","userId":""}},"outputId":"dc2dd440-fcc4-43c2-fc30-3e037c4906ef","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["X_cat shape: (200000, 28)\n","X_test_cat shape: (80000, 28)\n","Categorical columns: ['specialty_x', 'booking_channel', 'appointment_type', 'sex']\n"]}]},{"cell_type":"code","source":["cat_features_idx = [X_cat.columns.get_loc(col) for col in cat_cols]\n","print(\"Categorical feature indices:\", cat_features_idx)"],"metadata":{"id":"9IGDZNV03Ma9","executionInfo":{"status":"ok","timestamp":1773483644295,"user_tz":-180,"elapsed":5,"user":{"displayName":"","userId":""}},"outputId":"3d146d53-7f26-4715-e193-3bc49215eb4b","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Categorical feature indices: [0, 5, 6, 14]\n"]}]},{"cell_type":"code","source":["!pip install catboost -q"],"metadata":{"id":"9VtdKktM3NSG","executionInfo":{"status":"ok","timestamp":1773483656308,"user_tz":-180,"elapsed":4156,"user":{"displayName":"","userId":""}},"outputId":"9ff7b164-cddf-4251-ffcf-f8509277a849","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m97.1/97.1 MB\u001b[0m \u001b[31m25.5 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25h"]}]},{"cell_type":"code","source":["from catboost import CatBoostClassifier\n","from sklearn.metrics import average_precision_score\n","import numpy as np\n","\n","oof_preds_cat = np.zeros(len(X_cat))\n","test_preds_cat = np.zeros(len(X_test_cat))\n","fold_scores_cat = []\n","\n","for fold, (train_idx, val_idx) in enumerate(skf.split(X_cat, y_cat), 1):\n","    print(f\"\\n========== Fold {fold} ==========\")\n","\n","    X_train, X_val = X_cat.iloc[train_idx].copy(), X_cat.iloc[val_idx].copy()\n","    y_train, y_val = y_cat.iloc[train_idx], y_cat.iloc[val_idx]\n","\n","    model_cat = CatBoostClassifier(\n","        iterations=3000,\n","        learning_rate=0.03,\n","        depth=6,\n","        eval_metric=\"PRAUC\",\n","        loss_function=\"Logloss\",\n","        random_seed=42,\n","        verbose=200\n","    )\n","\n","    model_cat.fit(\n","        X_train, y_train,\n","        cat_features=cat_features_idx,\n","        eval_set=(X_val, y_val),\n","        use_best_model=True,\n","        early_stopping_rounds=200\n","    )\n","\n","    val_pred = model_cat.predict_proba(X_val)[:, 1]\n","    test_pred = model_cat.predict_proba(X_test_cat)[:, 1]\n","\n","    fold_score = average_precision_score(y_val, val_pred)\n","    fold_scores_cat.append(fold_score)\n","\n","    oof_preds_cat[val_idx] = val_pred\n","    test_preds_cat += test_pred / skf.n_splits\n","\n","    print(f\"Fold {fold} PR-AUC: {fold_score:.6f}\")\n","\n","print(\"\\n==============================\")\n","print(\"Fold scores:\", fold_scores_cat)\n","print(\"Mean CV PR-AUC:\", np.mean(fold_scores_cat))\n","print(\"OOF PR-AUC:\", average_precision_score(y_cat, oof_preds_cat))"],"metadata":{"id":"uxpQ-5l73PNa","executionInfo":{"status":"ok","timestamp":1773483785887,"user_tz":-180,"elapsed":118778,"user":{"displayName":"","userId":""}},"outputId":"e297c35f-2328-461f-eb63-ded4f6b51b66","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","========== Fold 1 ==========\n","0:\tlearn: 0.4765355\ttest: 0.4814789\tbest: 0.4814789 (0)\ttotal: 72.3ms\tremaining: 3m 36s\n","200:\tlearn: 0.5027244\ttest: 0.5037891\tbest: 0.5037891 (200)\ttotal: 5.67s\tremaining: 1m 18s\n","400:\tlearn: 0.5094621\ttest: 0.5050389\tbest: 0.5050750 (384)\ttotal: 11.3s\tremaining: 1m 13s\n","600:\tlearn: 0.5172285\ttest: 0.5050645\tbest: 0.5051730 (423)\ttotal: 16.9s\tremaining: 1m 7s\n","Stopped by overfitting detector  (200 iterations wait)\n","\n","bestTest = 0.5051729887\n","bestIteration = 423\n","\n","Shrink model to first 424 iterations.\n","Fold 1 PR-AUC: 0.505225\n","\n","========== Fold 2 ==========\n","0:\tlearn: 0.4778250\ttest: 0.4770787\tbest: 0.4770787 (0)\ttotal: 21.5ms\tremaining: 1m 4s\n","200:\tlearn: 0.5036920\ttest: 0.4979053\tbest: 0.4979098 (199)\ttotal: 5.63s\tremaining: 1m 18s\n","400:\tlearn: 0.5100260\ttest: 0.4988374\tbest: 0.4988655 (382)\ttotal: 11.2s\tremaining: 1m 12s\n","600:\tlearn: 0.5171603\ttest: 0.4990664\tbest: 0.4991351 (582)\ttotal: 16.9s\tremaining: 1m 7s\n","Stopped by overfitting detector  (200 iterations wait)\n","\n","bestTest = 0.4991351467\n","bestIteration = 582\n","\n","Shrink model to first 583 iterations.\n","Fold 2 PR-AUC: 0.499202\n","\n","========== Fold 3 ==========\n","0:\tlearn: 0.47